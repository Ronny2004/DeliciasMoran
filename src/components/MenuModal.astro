---
const menuImage = "/assets/hero.webp";

const mainDishes = [
    {
        title: "Tripas Asadas",
        price: "$2.50",
        ingredients: [
            "Tripa de res premium",
            "Marinado de ajo y comino",
            "Papas doradas",
            "Mote tierno",
        ],
    },
    {
        title: "Papas con Cuero",
        price: "$2.50",
        ingredients: [
            "Papas seleccionadas",
            "Cuero de chancho tierno",
            "Salsa espesa de maní",
            "Cebolla y cilantro",
        ],
    },
    {
        title: "Papas con Librillo",
        price: "$2.50",
        ingredients: [
            "Librillo de res tierno",
            "Papas harinosas",
            "Salsa de maní y leche",
            "Acompañante de aguacate",
        ],
    },
    {
        title: "Caldo de 31",
        price: "$2.50",
        ingredients: [
            "Menudencias de res",
            "Hierbas del huerto",
            "Papas cocidas",
            "Cebolla blanca y ajo",
        ],
    },
    {
        title: "Menudo de Chancho",
        price: "$2.50",
        ingredients: [
            "Vísceras de chancho",
            "Mote pelado",
            "Hierbabuena fresca",
            "Refrito de achiote",
        ],
    },
];

const drinks = [
    {
        title: "Colas Varias",
        price: "$0.50",
        ingredients: [
            "Medianas personales",
            "Siempre heladas",
            "Variedad de sabores",
        ],
    },
];
---

<div id="menuModal" class="modal">
    <div class="modal-content">
        <button class="close-modal" type="button" aria-label="Cerrar menú">&times;</button>
        <div class="modal-header">
            <div class="header-main">
                <img src="/assets/logo.webp" alt="Logo" />
                <h2>Nuestra Carta</h2>
            </div>
            <p>Sabor 100% Tradicional</p>
            <p>Toca un plato para ver detalles</p>
        </div>

        <div class="modal-body">
            <div class="rustic-menu-section">
                <h4>Platos de la Casa</h4>
                <div class="rustic-menu-grid">
                    {
                        mainDishes.map((dish) => (
                            <div class="rustic-menu-item">
                                <div class="item-header">
                                    <h3>{dish.title}</h3>
                                    <span class="item-price">{dish.price}</span>
                                </div>
                                <div class="item-details">
                                    <div class="detail-img">
                                        <img
                                            src={menuImage}
                                            alt={dish.title}
                                            loading="lazy"
                                            decoding="async"
                                        />
                                    </div>
                                    <div class="detail-info">
                                        <h5>Ingredientes:</h5>
                                        <ul>
                                            {dish.ingredients.map((i) => (
                                                <li>{i}</li>
                                            ))}
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>

            <div class="rustic-menu-section drinks-section">
                <h4>Bebidas</h4>
                <div class="rustic-menu-grid">
                    {
                        drinks.map((drink) => (
                            <div class="rustic-menu-item">
                                <div class="item-header">
                                    <h3>{drink.title}</h3>
                                    <span class="item-price">
                                        {drink.price}
                                    </span>
                                </div>
                                <div class="item-details">
                                    <div class="detail-img">
                                        <img
                                            src={menuImage}
                                            alt={drink.title}
                                            loading="lazy"
                                            decoding="async"
                                        />
                                    </div>
                                    <div class="detail-info">
                                        <ul>
                                            {drink.ingredients.map((i) => (
                                                <li>{i}</li>
                                            ))}
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>
        </div>

        <div class="modal-footer">
            <p>Precios incluyen impuestos</p>
        </div>
    </div>
</div>

<style>
    .modal {
        display: none;
        position: fixed;
        z-index: 2000;
        left: 0;
        top: 0;
        width: 100%;
        height: 100vh;
        overflow-y: auto;
        background-color: rgba(0, 0, 0, 0.85);
        backdrop-filter: blur(5px);
        justify-content: center;
        align-items: flex-start;
    }

    .modal.active {
        display: flex;
    }
    .modal-content * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    .modal-content {
        background: url("/assets/parchment.webp") no-repeat center center;
        background-size: 100% 100%;
        margin: 20px auto;
        padding: 120px 100px 140px 100px;
        width: 92%;
        max-width: 650px;
        min-height: 1000px;
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        position: relative;
        border-radius: 0;
        color: #4a3016;
        font-family: "Lora", serif;
        animation: fadeInUp 0.5s ease;
        box-shadow: none;
        background-color: transparent;
        border: none;
    }

    @media (max-width: 992px) {
        .modal-content {
            padding: 60px 40px;
            height: auto;
            min-height: 90vh;
            margin: 20px auto;
        }
    }

    .modal-header {
        text-align: center;
        border-bottom: 2px solid rgba(74, 48, 22, 0.2);
        padding-bottom: 15px;
        margin-bottom: 5px;
    }

    .header-main {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 15px;
        margin-bottom: 5px;
    }

    .modal-header img {
        height: 50px;
        margin: 0;
    }

    .modal-header h2 {
        font-size: 2.8rem;
        margin: 0;
        color: #5d2e0a;
        font-family: var(--font-script);
        font-weight: 700;
        line-height: 1;
    }

    .modal-header p {
        font-size: 1rem;
        font-style: italic;
        color: #8b4513;
        margin-top: 10px;
        opacity: 0.9;
    }

    .close-modal {
        position: absolute;
        right: 20px;
        top: 20px;
        color: #ffffff;
        font-size: 5rem;
        font-weight: bold;
        cursor: pointer;
        z-index: 10;
        transition: var(--transition);
        background: none;
        border: 0;
        line-height: 1;
    }

    .close-modal:hover {
        transform: scale(1.1);
        color: var(--accent);
    }

    .modal-body {
        flex: 1;
        padding-right: 5px;
    }

    .rustic-menu-section h4 {
        color: #5d2e0a;
        font-size: 1.4rem;
        border-bottom: 2px solid rgba(139, 69, 19, 0.15);
        margin: 5px 0 15px 0;
        padding-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .rustic-menu-section:last-of-type {
        margin-bottom: 0;
    }

    .drinks-section {
        margin-top: 20px;
    }

    .rustic-menu-item:last-child {
        border-bottom: none; /* Quitamos la línea punteada al último item para que no ensucie */
    }

    .rustic-menu-grid {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .rustic-menu-item {
        border-bottom: 1px dotted rgba(74, 48, 22, 0.3);
        padding: 10px 0;
        cursor: pointer;
        transition: background 0.3s ease;
    }

    .rustic-menu-item:hover {
        background: rgba(139, 69, 19, 0.05);
    }

    .item-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .rustic-menu-item h3 {
        font-size: 1.8rem;
        margin: 0;
        color: #5d2e0a;
        font-family: var(--font-script);
        font-weight: 700;
    }

    .item-price {
        font-weight: bold;
        font-size: 1.3rem;
        color: #8b4513;
    }

    .item-details {
        display: none;
        margin-top: 20px;
        padding: 20px;
        background: rgba(139, 69, 19, 0.05);
        border-radius: 8px;
        animation: fadeIn 0.4s ease;
    }

    .item-details.active {
        display: flex;
        gap: 20px;
    }

    .detail-img {
        flex: 0 0 150px;
        height: 120px;
        border-radius: 6px;
        overflow: hidden;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    }

    .detail-img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .detail-info {
        flex: 1;
    }

    .detail-info h5 {
        font-size: 1rem;
        margin-bottom: 10px;
        color: #5d2e0a;
    }

    .detail-info ul {
        list-style: none;
        font-size: 0.9rem;
        line-height: 1.4;
    }

    .detail-info li {
        margin-bottom: 4px;
        position: relative;
        padding-left: 15px;
    }

    .detail-info li::before {
        content: "•";
        position: absolute;
        left: 0;
        color: var(--accent);
    }

    .modal-footer {
        text-align: center;
        padding-bottom: 70px;
        margin-top: 80px;
        font-size: 1rem;
        color: #8b4513;
        opacity: 1;
        font-weight: 800;
        font-style: italic;
    }

    @media (max-width: 600px) {
        .modal-content {
            padding: 100px 30px 80px 30px;
            width: 100%;
            height: auto;
            min-height: auto;
            margin: 0;
            border-radius: 0;
        }
        .modal-header h2 {
            font-size: 2rem;
        }
    }
</style>

<script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
        const modal = document.getElementById("menuModal");
        const btn = document.querySelector(".btn-open-modal");
        const closeButton = document.querySelector(".close-modal");

        const closeModal = () => {
            if (!modal) return;
            modal.classList.remove("active");
            document.body.style.overflow = "";
        };

        if (btn && modal) {
            btn.addEventListener("click", () => {
                modal.classList.add("active");
                document.body.style.overflow = "hidden";
            });
        }

        if (closeButton) {
            closeButton.addEventListener("click", closeModal);
        }

        modal?.addEventListener("click", (event) => {
            if (event.target === modal) {
                closeModal();
            }
        });

        document.addEventListener("keydown", (event) => {
            if (event.key === "Escape" && modal?.classList.contains("active")) {
                closeModal();
            }
        });

        const menuItems = document.querySelectorAll(".rustic-menu-item");
        menuItems.forEach((item) => {
            item.addEventListener("click", () => {
                const details = item.querySelector(".item-details");
                if (!details) return;
                const isActive = details.classList.contains("active");

                document.querySelectorAll(".item-details").forEach((d) => {
                    d.classList.remove("active");
                });

                if (!isActive) {
                    details.classList.add("active");
                }
            });
        });
    });
</script>
