# Gemini API Key
# Obtener en: https://aistudio.google.com/apikey
GEMINI_API_KEY=tu_api_key_aqui

# Telegram Bot (opcional - para notificaciones de reservas)
# 1. Crear bot en https://t.me/BotFather → copiar el token
# 2. Enviar /start al bot desde Telegram
# 3. Visitar https://api.telegram.org/bot<TOKEN>/getUpdates para obtener el chat_id
TELEGRAM_BOT_TOKEN=tu_bot_token_aqui
TELEGRAM_OWNER_CHAT_ID=tu_chat_id_aqui

# Cloudflare Turnstile (protección antispam)
# Crear un widget en: https://dash.cloudflare.com/?to=/:account/turnstile
PUBLIC_TURNSTILE_SITE_KEY=tu_site_key_publica
TURNSTILE_SECRET_KEY=tu_secret_key_privada

# Dominios adicionales permitidos, separados por coma (opcional)
# El dominio actual de la solicitud siempre se permite.
ALLOWED_ORIGINS=https://tudominio.com
